generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  COORDINATION
  ADMIN
  ASSISTANT
  UNIT
  MANAGER
}

enum UnitType {
  UBS
  UPA
  HOSPITAL
  CAPS
  OTHER
}

enum ItemCategory {
  MEDICATION
  CORRELATE
}

enum MovementType {
  ENTRY_PURCHASE
  ENTRY_EXCHANGE
  ENTRY_ADJUSTMENT
  ENTRY_RETURN
  EXIT_SUPPLY
  EXIT_EXCHANGE
  EXIT_ADJUSTMENT
  EXIT_DISPOSAL
}

enum ExchangeStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  READY
  EXECUTED
  COMPLETED
  CANCELLED
}

enum GeraStatus {
  RECEIVED
  TRIAGING
  COMPLETED
  DISPATCHED
  CANCELLED
}

enum GeraItemStatus {
  PENDING
  APPROVED
  DENIED
}

enum GeraType {
  MONTHLY
  EXTRAORDINARY
  URGENT
}

model Sector {
  id           String    @id @default(cuid())
  name         String    @unique
  code         String    @unique
  responsible  String
  description  String?
  active       Boolean   @default(true)
  itemSequence Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  users     User[]
  items     Item[]
  exchanges Exchange[]
  movements Movement[]
  geraItems GeraItem[]

  @@index([name])
  @@index([active])
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  unitId       String?
  unit         Unit?     @relation(fields: [unitId], references: [id])
  sectorId     String?
  sector       Sector?   @relation(fields: [sectorId], references: [id])
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  exchangesCreated  Exchange[] @relation("ExchangeCreatedBy")
  exchangesApproved Exchange[] @relation("ExchangeApprovedBy")
  movements         Movement[]
  gerasRegistered   Gera[]     @relation("GeraRegisteredBy")
  geraItemsTriaged  GeraItem[] @relation("GeraItemTriagedBy")

  @@index([email])
  @@index([unitId])
  @@index([sectorId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

model Unit {
  id          String    @id @default(cuid())
  name        String
  type        UnitType
  address     String?
  responsible String
  contact     String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users     User[]
  movements Movement[]
  geras     Gera[]

  @@index([name])
}

model Item {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String
  category      ItemCategory
  unitOfMeasure String
  manufacturer  String?
  controlled344 Boolean      @default(false)
  unitValue     Decimal?     @db.Decimal(12, 4)
  active        Boolean      @default(true)
  sectorId      String
  sector        Sector       @relation(fields: [sectorId], references: [id])
  sequence      Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  lots            Lot[]
  exchangeOutputs ExchangeOutput[]
  exchangeInputs  ExchangeInput[]
  movements       Movement[]
  geraItems       GeraItem[]
  externalMappings ExternalCodeMapping[]

  @@unique([sectorId, sequence])
  @@index([code])
  @@index([sectorId])
  @@index([category])
  @@index([controlled344])
  @@index([active])
}

model Lot {
  id                String    @id @default(cuid())
  itemId            String
  item              Item      @relation(fields: [itemId], references: [id])
  lotNumber         String
  manufacturingDate DateTime?
  expirationDate    DateTime
  initialQuantity   Decimal   @db.Decimal(12, 3)
  currentBalance    Decimal   @db.Decimal(12, 3)
  unitCost          Decimal?  @db.Decimal(12, 4)
  supplier          String?
  invoiceNumber     String?
  notes             String?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  exchangeOutputs ExchangeOutput[]
  exchangeInputs  ExchangeInput[]
  movements       Movement[]
  geraItems       GeraItem[]

  @@unique([itemId, lotNumber])
  @@index([itemId])
  @@index([expirationDate])
  @@index([active])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  sectorId  String?
  payload   Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([sectorId])
  @@index([action])
}

model Movement {
  id                String       @id @default(cuid())
  type              MovementType
  itemId            String
  item              Item         @relation(fields: [itemId], references: [id])
  lotId             String
  lot               Lot          @relation(fields: [lotId], references: [id])
  sectorId          String
  sector            Sector       @relation(fields: [sectorId], references: [id])
  quantity          Decimal      @db.Decimal(12, 3)
  unitValue         Decimal?     @db.Decimal(12, 4)
  balanceAfter      Decimal      @db.Decimal(12, 3)
  unitId            String?
  unit              Unit?        @relation(fields: [unitId], references: [id])
  invoiceNumber     String?
  partnerExchangeId String?
  reason            String?
  reversalOfId      String?
  reversalOf        Movement?    @relation("Reversal", fields: [reversalOfId], references: [id])
  reversals         Movement[]   @relation("Reversal")
  createdById       String
  createdBy         User         @relation(fields: [createdById], references: [id])
  createdAt         DateTime     @default(now())
  geraItems         GeraItem[]

  @@index([itemId])
  @@index([lotId])
  @@index([sectorId])
  @@index([type])
  @@index([unitId])
  @@index([createdAt])
  @@index([createdById])
  @@index([partnerExchangeId])
}

model ExternalPartner {
  id              String    @id @default(cuid())
  name            String    @unique
  cnpj            String?
  responsibleName String
  contact         String?
  notes           String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  exchanges Exchange[]

  @@index([name])
  @@index([active])
}

model Exchange {
  id                 String          @id @default(cuid())
  code               String          @unique
  sequence           Int
  date               DateTime        @default(now())
  status             ExchangeStatus  @default(DRAFT)
  justification      String
  tolerancePct       Decimal         @db.Decimal(5, 2)
  partnerId          String
  partner            ExternalPartner @relation(fields: [partnerId], references: [id])
  sectorId           String
  sector             Sector          @relation(fields: [sectorId], references: [id])
  createdById        String
  createdBy          User            @relation("ExchangeCreatedBy", fields: [createdById], references: [id])
  approvedById       String?
  approvedBy         User?           @relation("ExchangeApprovedBy", fields: [approvedById], references: [id])
  approvedAt         DateTime?
  rejectionReason    String?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  outputs ExchangeOutput[]
  inputs  ExchangeInput[]

  @@index([code])
  @@index([status])
  @@index([partnerId])
  @@index([sectorId])
  @@index([date])
}

model ExchangeOutput {
  id         String    @id @default(cuid())
  exchangeId String
  exchange   Exchange  @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item      @relation(fields: [itemId], references: [id])
  lotId      String
  lot        Lot       @relation(fields: [lotId], references: [id])
  quantity   Decimal   @db.Decimal(12, 3)
  unitValue  Decimal   @db.Decimal(12, 4)
  subtotal   Decimal   @db.Decimal(14, 2)
  executedAt DateTime?
  movementId String?
  notes      String?
  createdAt  DateTime  @default(now())

  @@index([exchangeId])
  @@index([itemId])
  @@index([lotId])
  @@index([executedAt])
}

model ExchangeInput {
  id                 String    @id @default(cuid())
  exchangeId         String
  exchange           Exchange  @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  itemId             String
  item               Item      @relation(fields: [itemId], references: [id])
  lotId              String?
  lot                Lot?      @relation(fields: [lotId], references: [id])
  declaredLotNumber  String?
  declaredExpiration DateTime?
  quantity           Decimal   @db.Decimal(12, 3)
  unitValue          Decimal   @db.Decimal(12, 4)
  subtotal           Decimal   @db.Decimal(14, 2)
  executedAt         DateTime?
  movementId         String?
  notes              String?
  createdAt          DateTime  @default(now())

  @@index([exchangeId])
  @@index([itemId])
  @@index([executedAt])
}

model Setting {
  id                        String   @id @default("singleton")
  requireExchangeApproval   Boolean  @default(false)
  exchangeTolerancePct      Decimal  @db.Decimal(5, 2) @default(5.00)
  exchangeApprovalThreshold Decimal  @db.Decimal(14, 2) @default(0)
  exchangeSequence          Int      @default(0)
  geraSequence              Int      @default(0)
  updatedAt                 DateTime @updatedAt
  updatedById               String?
}

model Gera {
  id               String     @id @default(cuid())
  code             String     @unique
  externalNumber   String?
  status           GeraStatus @default(RECEIVED)
  type             GeraType   @default(MONTHLY)

  unitId           String
  unit             Unit       @relation(fields: [unitId], references: [id])

  requestedAt      DateTime
  expectedDelivery DateTime?
  deadline         DateTime?

  importedFrom     String?
  importedFileUrl  String?

  registeredById   String
  registeredBy     User       @relation("GeraRegisteredBy", fields: [registeredById], references: [id])

  items            GeraItem[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  @@index([unitId])
  @@index([status])
  @@index([requestedAt])
  @@index([externalNumber])
}

model GeraItem {
  id              String         @id @default(cuid())
  geraId          String
  gera            Gera           @relation(fields: [geraId], references: [id], onDelete: Cascade)

  externalCode    String?
  description     String

  itemId          String?
  item            Item?          @relation(fields: [itemId], references: [id])

  sectorId        String?
  sector          Sector?        @relation(fields: [sectorId], references: [id])

  declaredBalance Decimal?       @db.Decimal(12, 3)
  consumption     Decimal?       @db.Decimal(12, 3)
  requested       Decimal        @db.Decimal(12, 3)

  status          GeraItemStatus @default(PENDING)
  approved        Decimal?       @db.Decimal(12, 3)
  denialReason    String?
  triagedById     String?
  triagedBy       User?          @relation("GeraItemTriagedBy", fields: [triagedById], references: [id])
  triagedAt       DateTime?

  movementId      String?
  movement        Movement?      @relation(fields: [movementId], references: [id])
  lotId           String?
  lot             Lot?           @relation(fields: [lotId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([geraId])
  @@index([itemId])
  @@index([sectorId])
  @@index([status])
}

model ExternalCodeMapping {
  id            String    @id @default(cuid())
  externalCode  String    @unique
  itemId        String
  item          Item      @relation(fields: [itemId], references: [id])
  confirmedById String?
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([itemId])
}
